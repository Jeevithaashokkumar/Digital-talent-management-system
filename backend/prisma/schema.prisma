generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  name             String
  email            String          @unique
  password         String
  role             String          @default("user")
  status           String          @default("active")
  otp              String?
  otpExpires       DateTime?
  createdAt        DateTime        @default(now())
  boards           Board[]         @relation("UserBoards")
  docs             Doc[]           @relation("UserDocs")
  files            File[]          @relation("UserFiles")
  folders          Folder[]        @relation("UserFolders")
  knowledgeNodes   KnowledgeNode[] @relation("UserKnowledgeNodes")
  receivedMessages Message[]       @relation("ReceivedMessages")
  sentMessages     Message[]       @relation("SentMessages")
  missions         Mission[]       @relation("UserMissions")
  neuralGraphs     NeuralGraph[]   @relation("UserNeuralGraphs")
  neuralNodes      NeuralNode[]    @relation("UserNeuralNodes")
  reactions        Reaction[]
  createdTasks     Task[]          @relation("AdminTasks")
  assignedTasks    Task[]          @relation("UserTasks")
  whiteboards      Whiteboard[]    @relation("UserWhiteboards")
  campaigns        Campaign[]      @relation("UserCampaigns")
  operations       Operation[]     @relation("UserOperations")
}

model Message {
  id         String     @id @default(uuid())
  content    String
  senderId   String
  receiverId String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  isPinned   Boolean    @default(false)
  replyToId  String?
  replyTo    Message?   @relation("MessageReplies", fields: [replyToId], references: [id])
  replies    Message[]  @relation("MessageReplies")
  receiver   User?      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User       @relation("SentMessages", fields: [senderId], references: [id])
  reactions  Reaction[]
}

model Reaction {
  id        String  @id @default(uuid())
  emoji     String
  userId    String
  messageId String
  message   Message @relation(fields: [messageId], references: [id])
  user      User    @relation(fields: [userId], references: [id])
}

model Board {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdBy   String
  createdAt   DateTime @default(now())
  creator     User     @relation("UserBoards", fields: [createdBy], references: [id])
  lists       List[]
  tasks       Task[]
}

model List {
  id        String   @id @default(uuid())
  title     String
  order     Int      @default(0)
  boardId   String
  createdAt DateTime @default(now())
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  order       Int       @default(0)
  dueDate     DateTime?
  labels      String    @default("")
  listId      String?
  boardId     String?
  folderId    String?
  assignedTo  String?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  subTasks    SubTask[]
  creator     User      @relation("AdminTasks", fields: [createdBy], references: [id])
  assignee    User?     @relation("UserTasks", fields: [assignedTo], references: [id])
  folder      Folder?   @relation(fields: [folderId], references: [id])
  board       Board?    @relation(fields: [boardId], references: [id])
  list        List?     @relation(fields: [listId], references: [id])
}

model SubTask {
  id        String  @id @default(uuid())
  title     String
  completed Boolean @default(false)
  taskId    String
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Folder {
  id             String       @id @default(uuid())
  name           String
  parentFolderId String?
  createdBy      String
  createdAt      DateTime     @default(now())
  docs           Doc[]
  files          File[]
  creator        User         @relation("UserFolders", fields: [createdBy], references: [id])
  parent         Folder?      @relation("FolderHierarchy", fields: [parentFolderId], references: [id])
  subFolders     Folder[]     @relation("FolderHierarchy")
  tasks          Task[]
  whiteboards    Whiteboard[]
}

model Doc {
  id           String   @id @default(uuid())
  title        String
  content      String?
  folderId     String?
  createdBy    String
  lastEditedBy String?
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  creator      User     @relation("UserDocs", fields: [createdBy], references: [id])
  folder       Folder?  @relation(fields: [folderId], references: [id])
}

model Whiteboard {
  id        String   @id @default(uuid())
  title     String
  data      String?
  folderId  String?
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creator   User     @relation("UserWhiteboards", fields: [createdBy], references: [id])
  folder    Folder?  @relation(fields: [folderId], references: [id])
}

model File {
  id           String   @id @default(uuid())
  name         String
  originalName String
  mimeType     String
  size         Int
  path         String
  url          String
  folderId     String?
  uploadedBy   String
  createdAt    DateTime @default(now())
  uploader     User     @relation("UserFiles", fields: [uploadedBy], references: [id])
  folder       Folder?  @relation(fields: [folderId], references: [id])
}

model NeuralNode {
  id          String       @id @default(uuid())
  title       String
  description String?
  type        String
  status      String       @default("active")
  priority    String       @default("medium")
  createdBy   String
  graphId     String?
  linkedNodes String       @default("[]")
  position    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  graph       NeuralGraph? @relation("GraphNodes", fields: [graphId], references: [id])
  creator     User         @relation("UserNeuralNodes", fields: [createdBy], references: [id])
}

model NeuralGraph {
  id          String       @id @default(uuid())
  title       String
  description String?
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  creator     User         @relation("UserNeuralGraphs", fields: [createdBy], references: [id])
  nodes       NeuralNode[] @relation("GraphNodes")
}

model KnowledgeNode {
  id        String                  @id @default(uuid())
  name      String
  type      String
  sourceId  String?
  createdBy String
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  creator   User                    @relation("UserKnowledgeNodes", fields: [createdBy], references: [id])
  incoming  KnowledgeRelationship[] @relation("TargetNode")
  outgoing  KnowledgeRelationship[] @relation("SourceNode")
}

model KnowledgeRelationship {
  id           String        @id @default(uuid())
  sourceNodeId String
  targetNodeId String
  relationType String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  targetNode   KnowledgeNode @relation("TargetNode", fields: [targetNodeId], references: [id])
  sourceNode   KnowledgeNode @relation("SourceNode", fields: [sourceNodeId], references: [id])
}

model Mission {
  id            String    @id @default(uuid())
  title         String
  description   String?
  status        String    @default("not_started")
  priority      String    @default("medium")
  assignedUsers String    @default("[]")
  startDate     DateTime?
  dueDate       DateTime?
  progress      Int       @default(0)
  relatedTasks  String    @default("[]")
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  creator       User      @relation("UserMissions", fields: [createdBy], references: [id])
}

model Campaign {
  id           String    @id @default(uuid())
  campaignName String
  type         String
  status       String    @default("planning")
  budget       Float     @default(0)
  startDate    DateTime?
  endDate      DateTime?
  assignedTeam String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  creator      User      @relation("UserCampaigns", fields: [createdBy], references: [id])
}

model Operation {
  id              String    @id @default(uuid())
  operationName   String
  department      String
  status          String    @default("pending")
  priority        String    @default("medium")
  region          String
  assignedManager String?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  creator         User      @relation("UserOperations", fields: [createdBy], references: [id])
}
