generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  role       String    @default("user") // "user" or "admin"
  status     String    @default("active") // "active" or "inactive"
  otp        String?
  otpExpires DateTime?
  createdAt  DateTime  @default(now())

  boards           Board[]         @relation("UserBoards")
  assignedTasks    Task[]          @relation("UserTasks")
  createdTasks     Task[]          @relation("AdminTasks")
  folders          Folder[]        @relation("UserFolders")
  docs             Doc[]           @relation("UserDocs")
  whiteboards      Whiteboard[]    @relation("UserWhiteboards")
  files            File[]          @relation("UserFiles")
  neuralNodes      NeuralNode[]    @relation("UserNeuralNodes")
  neuralGraphs     NeuralGraph[]   @relation("UserNeuralGraphs")
  knowledgeNodes   KnowledgeNode[] @relation("UserKnowledgeNodes")
  missions         Mission[]       @relation("UserMissions")
  sentMessages     Message[]       @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  reactions        Reaction[]
}

model Message {
  id         String   @id @default(uuid())
  content    String
  senderId   String
  receiverId String? // Null for team chat (broadcast)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isPinned   Boolean  @default(false)
  replyToId  String?

  sender    User       @relation("SentMessages", fields: [senderId], references: [id])
  receiver  User?      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  replyTo   Message?   @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[]  @relation("MessageReplies")
  reactions Reaction[]
}

model Reaction {
  id        String  @id @default(uuid())
  emoji     String
  userId    String
  messageId String
  user      User    @relation(fields: [userId], references: [id])
  message   Message @relation(fields: [messageId], references: [id])
}

model Board {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdBy   String
  createdAt   DateTime @default(now())

  creator User   @relation("UserBoards", fields: [createdBy], references: [id])
  lists   List[]
  tasks   Task[]
}

model List {
  id        String   @id @default(uuid())
  title     String
  order     Int      @default(0)
  boardId   String
  createdAt DateTime @default(now())

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("todo") // "todo", "in-progress", "done"
  priority    String    @default("medium") // "low", "medium", "high"
  order       Int       @default(0)
  dueDate     DateTime?
  labels      String    @default("") // Comma-separated tags

  listId     String?
  boardId    String?
  folderId   String?
  assignedTo String?
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  list     List?     @relation(fields: [listId], references: [id])
  board    Board?    @relation(fields: [boardId], references: [id])
  folder   Folder?   @relation(fields: [folderId], references: [id])
  subTasks SubTask[]
  assignee User?     @relation("UserTasks", fields: [assignedTo], references: [id])
  creator  User      @relation("AdminTasks", fields: [createdBy], references: [id])
}

model SubTask {
  id        String  @id @default(uuid())
  title     String
  completed Boolean @default(false)
  taskId    String
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Folder {
  id             String   @id @default(uuid())
  name           String
  parentFolderId String?
  createdBy      String
  createdAt      DateTime @default(now())

  parent      Folder?      @relation("FolderHierarchy", fields: [parentFolderId], references: [id])
  subFolders  Folder[]     @relation("FolderHierarchy")
  creator     User         @relation("UserFolders", fields: [createdBy], references: [id])
  tasks       Task[]
  docs        Doc[]
  whiteboards Whiteboard[]
  files       File[]
}

model Doc {
  id           String   @id @default(uuid())
  title        String
  content      String?
  folderId     String?
  createdBy    String
  lastEditedBy String?
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  folder  Folder? @relation(fields: [folderId], references: [id])
  creator User    @relation("UserDocs", fields: [createdBy], references: [id])
}

model Whiteboard {
  id        String   @id @default(uuid())
  title     String
  data      String? 
  folderId  String?
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folder  Folder? @relation(fields: [folderId], references: [id])
  creator User    @relation("UserWhiteboards", fields: [createdBy], references: [id])
}

model File {
  id           String   @id @default(uuid())
  name         String
  originalName String
  mimeType     String
  size         Int
  path         String
  url          String
  folderId     String?
  uploadedBy   String
  createdAt    DateTime @default(now())

  folder   Folder? @relation(fields: [folderId], references: [id])
  uploader User    @relation("UserFiles", fields: [uploadedBy], references: [id])
}

model NeuralNode {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String // idea, task, note, insight
  status      String   @default("active") // active, archived
  priority    String   @default("medium") // low, medium, high
  createdBy   String
  graphId     String?
  linkedNodes String   @default("[]") // Store as JSON string array
  position    String? // Store as JSON string {x, y}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User         @relation("UserNeuralNodes", fields: [createdBy], references: [id])
  graph   NeuralGraph? @relation("GraphNodes", fields: [graphId], references: [id])
}

model NeuralGraph {
  id          String       @id @default(uuid())
  title       String
  description String?
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  nodes       NeuralNode[] @relation("GraphNodes")

  creator User @relation("UserNeuralGraphs", fields: [createdBy], references: [id])
}

model KnowledgeNode {
  id        String   @id @default(uuid())
  name      String
  type      String // concept, document, task, user
  sourceId  String? // Original entity ID (taskId, docId, etc)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator  User                    @relation("UserKnowledgeNodes", fields: [createdBy], references: [id])
  outgoing KnowledgeRelationship[] @relation("SourceNode")
  incoming KnowledgeRelationship[] @relation("TargetNode")
}

model KnowledgeRelationship {
  id           String   @id @default(uuid())
  sourceNodeId String
  targetNodeId String
  relationType String // depends_on, related_to, assigned_to
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sourceNode KnowledgeNode @relation("SourceNode", fields: [sourceNodeId], references: [id])
  targetNode KnowledgeNode @relation("TargetNode", fields: [targetNodeId], references: [id])
}

model Mission {
  id            String    @id @default(uuid())
  title         String
  description   String?
  status        String    @default("not_started") // not_started, in_progress, completed, blocked
  priority      String    @default("medium") // low, medium, high
  assignedUsers String    @default("[]") // JSON string array of User IDs
  startDate     DateTime?
  dueDate       DateTime?
  progress      Int       @default(0) // percentage
  relatedTasks  String    @default("[]") // JSON string array of task IDs
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator User @relation("UserMissions", fields: [createdBy], references: [id])
}
